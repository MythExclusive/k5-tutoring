<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>K-5 Weekend Tutoring</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

  <!-- Header -->
  <header>
    <div class="clouds">
      <div class="cloud cloud1">☁️</div>
      <div class="cloud cloud2">☁️</div>
      <div class="cloud cloud3">☁️</div>
    </div>
    <h1>🌟 K-5 Weekend Tutoring 🌟</h1>
    <div class="bouncing-emojis">
      <span>🎉</span>
      <span>✨</span>
      <span>📚</span>
    </div>
    <p>Fun learning that helps kids grow and succeed! 🎈</p>
  </header>

  <section>

    <!-- About Me -->
    <div class="card">
      <h2>👋 About Me</h2>
      <p>Hi! I'm a friendly tutor offering weekend help for students in kindergarten through 5th grade. I make learning fun, simple, and stress-free! 😊</p>
    </div>

    <!-- Subjects -->
    <div class="card">
      <h2>📚 What I Can Help With</h2>
      <ul>
        <li>➕ Math (basic math, fractions, word problems)</li>
        <li>📖 Reading & Writing</li>
        <li>📝 Homework Help</li>
        <li>🧠 Study Skills</li>
      </ul>
    </div>

    <!-- Style -->
    <div class="card">
      <h2>✨ My Style</h2>
      <ul>
        <li>👍 Easy to understand</li>
        <li>💛 Patient and encouraging</li>
        <li>🌈 Builds confidence</li>
      </ul>
    </div>

    <!-- Step-by-Step Booking -->
    <div class="card">
      <h2>📝 How Booking Works</h2>
      <div class="steps">
        <div class="step">
          <span class="step-icon">💡</span>
          <p><strong>Step 1:</strong> View Pricing Packages</p>
        </div>
        <div class="step">
          <span class="step-icon">✉️</span>
          <p><strong>Step 2:</strong> Message me with preferred day/time</p>
        </div>
        <div class="step">
          <span class="step-icon">✅</span>
          <p><strong>Step 3:</strong> I confirm your session availability</p>
        </div>
        <div class="step">
          <span class="step-icon">💰</span>
          <p><strong>Step 4:</strong> Pay for your session once confirmed</p>
        </div>
      </div>
    </div>

    <!-- Pricing Packages -->
    <div class="card">
      <h2>💰 Pricing Packages</h2>
      <p>📌 Please message me first to confirm your child’s time. Pricing is per session.</p>
      <div class="pricing-cards">
        <div class="price-card">
          <h3>1 Hour</h3>
          <p class="price">$15</p>
          <p>Fun, focused session tailored to your child’s needs! 🎯</p>
        </div>
        <div class="price-card">
          <h3>2 Hours</h3>
          <p class="price">$25</p>
          <p>Double the fun and learning! 📝 Perfect for homework or extra practice.</p>
        </div>
      </div>
    </div>

    <!-- Contact Form -->
    <div class="card">
      <h2>📩 Contact</h2>
      <p>Please fill out the form below to confirm your session time! 💬</p>
      <form action="https://formspree.io/f/mykbzjor" method="POST" class="contact-form">
        <label>Name: <input type="text" name="name" placeholder="Your Name" required></label><br><br>
        <label>Email: <input type="email" name="email" placeholder="Your Email" required></label><br><br>
        <label>Message:<br>
          <textarea name="message" placeholder="Preferred day/time, grade, and topics to cover" required></textarea>
        </label><br><br>
        <button type="submit" class="btn">Send Message</button>
      </form>
    </div>

  </section>

  <!-- Footer -->
  <footer>
    <p>© 2026 K-5 Tutoring 🎓</p>
  </footer>

  <!-- Floating Stars -->
  <div class="stars">
    <span>⭐</span><span>✨</span><span>🌟</span><span>⭐</span><span>✨</span>
  </div>

</body>
</html>
